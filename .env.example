# Copy to `.env` and fill in. Never commit `.env` (it is gitignored).
#
# ── Vite (bundled into the site; must not contain secrets) ───────────────
# Public base URL for video files served from Cloudflare R2 (no trailing slash).
# Example custom domain: https://videos.example.com
# Example r2.dev: https://your-bucket-name.r2.dev
VITE_R2_PUBLIC_URL=

# Optional: only if your app uses ApiService with a backend base URL
# VITE_API_BASE_URL=

# Contact page: optional override for the protected email (otherwise obfuscated default in code).
# VITE_CONTACT_EMAIL=

# Cloudflare Turnstile (https://dash.cloudflare.com → Turnstile). Use a real site key in production.
# Local dev falls back to Cloudflare’s test key when unset.
# VITE_TURNSTILE_SITE_KEY=

# ── Cloudflare R2 upload script only (scripts/upload-to-r2.js) ──────────
# These are secrets. Do not put them in VITE_* vars.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Same host the browser uses for video URLs (often matches VITE_R2_PUBLIC_URL)
R2_PUBLIC_URL=
